---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import EmbedLayout from './EmbedLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import type { Locale } from '../i18n/config';
import { t } from '../i18n/labels';

type Props = CollectionEntry<'doc'>['data'] & {
	lang: Locale;
};

const { title, description, pubDate, updatedDate, heroImage, lang } = Astro.props;
const L = t(lang);
---

<EmbedLayout title={title} description={description} lang={lang} section="doc">
	<article>
		<div class="hero-image">
			{heroImage && <Image width={720} height={360} src={heroImage} alt="" />}
		</div>
		<div class="prose">
			<div class="title">
				<div class="date">
					<FormattedDate date={pubDate} locale={lang} />
					{
						updatedDate && (
							<div class="last-updated-on">
								{L.lastUpdatedOn}{' '}
								<FormattedDate date={updatedDate} locale={lang} />
							</div>
						)
					}
				</div>
				<h1>{title}</h1>
				<hr />
			</div>
			<slot />
		</div>
	</article>
</EmbedLayout>

<style>
	article {
		max-width: 720px;
		margin: 0 auto;
	}
	.hero-image {
		width: 100%;
		max-width: 560px;
		margin: 0 auto 1.25rem;
		padding: 0.75rem 1rem;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 12px;
		box-sizing: border-box;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.hero-image :global(img) {
		display: block;
		margin: 0 auto;
		max-height: 160px;
		width: auto;
		max-width: 100%;
		height: auto;
		object-fit: contain;
		border-radius: 8px;
	}
	.prose {
		width: 100%;
		max-width: 680px;
		margin: auto;
		padding: 0.5em 0 1em;
		color: var(--text);
	}
	.prose :global(img) {
		max-width: min(100%, 520px);
		margin: 0.75rem auto;
		display: block;
		height: auto;
	}
	.title {
		margin-bottom: 1em;
		padding: 0.5em 0 1em;
		text-align: center;
		line-height: 1.2;
	}
	.title h1 {
		margin: 0 0 0.5em 0;
	}
	.date {
		margin-bottom: 0.5em;
		color: var(--muted);
		font-size: 0.95rem;
	}
	.last-updated-on {
		font-style: italic;
		margin-top: 0.35em;
	}
</style>
