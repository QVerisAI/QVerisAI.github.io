---
import '../styles/prose.css';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import PostMeta from '../components/PostMeta.astro';
import TableOfContents from '../components/TableOfContents.astro';
import JsonLd from '../components/JsonLd.astro';
import type { Locale, Region } from '../i18n/config';
import { t } from '../i18n/labels';
import { localizedPath } from '../i18n/utils';

type Props = CollectionEntry<'doc'>['data'] & {
	lang: Locale;
	region?: Region;
	embed?: boolean;
	headings?: MarkdownHeading[];
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	lang,
	region = 'global',
	embed = false,
	headings = [],
} = Astro.props;

const L = t(lang);
const docIndexHref = localizedPath(lang, '/doc');
const breadcrumbItems = [
	{ label: L.doc, href: docIndexHref },
	{ label: title },
];
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://qveris.ai';
const breadcrumbLd = breadcrumbItems.map((item) => ({
	name: item.label,
	...(item.href && { url: `${site}${item.href}` }),
}));
---

<BaseLayout
	title={title}
	description={description}
	lang={lang}
	section="doc"
	region={region}
	embed={embed}
	ogType="article"
	image={heroImage}
	pubDate={pubDate}
	updatedDate={updatedDate}
>
	<JsonLd type="BlogPosting" data={{
		title,
		description,
		url: canonicalUrl,
		image: heroImage ? new URL(heroImage.src, Astro.url).toString() : undefined,
		pubDate,
		updatedDate,
		lang,
	}} />
	<JsonLd type="BreadcrumbList" data={{ items: breadcrumbLd }} />

	<div class="doc-layout">
		<article class="doc-content">
			<Breadcrumb items={breadcrumbItems} />

			<header class="doc-header">
				<h1 class="doc-header__title">{title}</h1>
				<PostMeta date={pubDate} lang={lang} />
				{updatedDate && (
					<p class="doc-header__updated">
						{L.lastUpdatedOn}{' '}
						<time datetime={updatedDate.toISOString()}>
							{updatedDate.toLocaleDateString(lang === 'cn' ? 'zh-CN' : 'en-US', {
								year: 'numeric',
								month: 'short',
								day: 'numeric',
							})}
						</time>
					</p>
				)}
			</header>

			{heroImage && (
				<figure class="doc-hero">
					<Image width={720} height={405} src={heroImage} alt={title} />
				</figure>
			)}

			<div class="prose">
				<slot />
			</div>
		</article>

		{headings.length > 0 && (
			<aside class="doc-sidebar">
				<TableOfContents headings={headings} lang={lang} />
			</aside>
		)}
	</div>
</BaseLayout>

<style>
	.doc-layout {
		display: grid;
		grid-template-columns: minmax(0, var(--qv-container-prose)) 220px;
		gap: 48px;
		max-width: calc(var(--qv-container-prose) + 220px + 48px);
		margin: 0 auto;
		padding: 0 24px;
		box-sizing: border-box;
	}

	.doc-content {
		min-width: 0;
	}

	.doc-sidebar {
		min-width: 0;
	}

	.doc-header {
		margin: 32px 0 28px;
	}

	.doc-header__title {
		font-size: clamp(26px, 3.5vw, 34px);
		font-weight: 400;
		letter-spacing: -0.035em;
		line-height: 1.15;
		margin: 0 0 16px;
		color: var(--qv-text-1);
	}

	.doc-header__updated {
		font-size: 13px;
		color: var(--qv-text-4);
		font-style: italic;
		margin: 8px 0 0;
	}

	.doc-hero {
		margin: 0 0 32px;
		border-radius: var(--qv-radius-md);
		overflow: hidden;
		border: 1px solid var(--border);
	}

	.doc-hero :global(img) {
		width: 100%;
		height: auto;
		display: block;
		border-radius: 0;
		border: none;
	}

	@media (max-width: 960px) {
		.doc-layout {
			grid-template-columns: 1fr;
			gap: 0;
			padding: 0 18px;
		}

		.doc-sidebar {
			display: none;
		}
	}
</style>
