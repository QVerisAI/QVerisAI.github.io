---
import BaseHead from '../components/BaseHead.astro';
import EmbedToolbar from '../components/EmbedToolbar.astro';
import type { Locale } from '../i18n/config';

interface Props {
	title: string;
	description: string;
	lang: Locale;
	section: 'blog' | 'doc';
}

const { title, description, lang, section } = Astro.props;
const htmlLang = lang === 'cn' ? 'zh-CN' : 'en';
---

<!doctype html>
<html lang={htmlLang}>
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body class="embed-body">
		<EmbedToolbar lang={lang} section={section} />
		<main class="embed-main">
			<slot />
		</main>
	</body>
</html>
