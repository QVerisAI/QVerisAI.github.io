---
import BaseHead from '../components/BaseHead.astro';
import Nav from '../components/Nav.astro';
import type { ImageMetadata } from 'astro';
import type { Locale, Region } from '../i18n/config';
import { getHtmlLang } from '../i18n/utils';

interface Props {
	title: string;
	description: string;
	lang: Locale;
	section: 'blog' | 'doc';
	region?: Region;
	embed?: boolean;
	// SEO pass-through
	ogType?: 'website' | 'article';
	image?: ImageMetadata;
	pubDate?: Date;
	updatedDate?: Date;
	author?: string;
	tags?: string[];
}

const {
	title,
	description,
	lang,
	section,
	region = 'global',
	embed = false,
	ogType = 'website',
	image,
	pubDate,
	updatedDate,
	author,
	tags,
} = Astro.props;
const htmlLang = getHtmlLang(lang);
---

<!doctype html>
<html lang={htmlLang}>
	<head>
		<BaseHead
			title={title}
			description={description}
			lang={lang}
			ogType={ogType}
			image={image}
			pubDate={pubDate}
			updatedDate={updatedDate}
			author={author}
			tags={tags}
		/>
		<slot name="head" />
	</head>
	<body class="embed-body">
		<Nav lang={lang} section={section} region={region} embed={embed} />
		<main class="embed-main">
			<slot />
		</main>
		<script src="../scripts/scroll-reveal.ts"></script>
		<script src="../scripts/code-copy.ts"></script>
		<script src="../scripts/toc-highlight.ts"></script>
	</body>
</html>
