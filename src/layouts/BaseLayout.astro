---
import BaseHead from '../components/BaseHead.astro';
import Nav from '../components/Nav.astro';
import type { Locale, Region } from '../i18n/config';
import { getHtmlLang } from '../i18n/utils';

interface Props {
	title: string;
	description: string;
	lang: Locale;
	section: 'blog' | 'doc';
	region?: Region;
	embed?: boolean;
}

const { title, description, lang, section, region = 'global', embed = false } = Astro.props;
const htmlLang = getHtmlLang(lang);
---

<!doctype html>
<html lang={htmlLang}>
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body class="embed-body">
		<Nav lang={lang} section={section} region={region} embed={embed} />
		<main class="embed-main">
			<slot />
		</main>
		<script src="../scripts/scroll-reveal.ts"></script>
		<script src="../scripts/code-copy.ts"></script>
		<script src="../scripts/toc-highlight.ts"></script>
	</body>
</html>
