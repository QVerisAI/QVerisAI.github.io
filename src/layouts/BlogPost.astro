---
import '../styles/prose.css';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Eyebrow from '../components/Eyebrow.astro';
import PostMeta from '../components/PostMeta.astro';
import Divider from '../components/Divider.astro';
import TableOfContents from '../components/TableOfContents.astro';
import type { Locale, Region } from '../i18n/config';
import { t } from '../i18n/labels';
import { localizedPath } from '../i18n/utils';

type NavLink = { href: string; title: string };

type Props = CollectionEntry<'blog'>['data'] & {
	lang: Locale;
	region?: Region;
	embed?: boolean;
	prevPost: NavLink | null;
	nextPost: NavLink | null;
	blogIndexHref: string;
	headings: MarkdownHeading[];
	readingTime: number;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	category,
	lang,
	region = 'global',
	embed = false,
	prevPost,
	nextPost,
	blogIndexHref,
	headings,
	readingTime,
} = Astro.props;

const L = t(lang);
const breadcrumbItems = [
	{ label: L.blog, href: blogIndexHref },
	...(category ? [{ label: category, href: blogIndexHref }] : []),
	{ label: title },
];
---

<BaseLayout title={title} description={description} lang={lang} section="blog" region={region} embed={embed}>
	<div class="post-layout">
		<article class="post-content">
			<Breadcrumb items={breadcrumbItems} />

			<header class="post-header">
				{category && <Eyebrow text={category} class="post-header__eyebrow" />}
				<h1 class="post-header__title">{title}</h1>
				<PostMeta date={pubDate} readingTime={readingTime} lang={lang} />
				{updatedDate && (
					<p class="post-header__updated">
						{L.lastUpdatedOn}{' '}
						<time datetime={updatedDate.toISOString()}>
							{updatedDate.toLocaleDateString(lang === 'cn' ? 'zh-CN' : 'en-US', {
								year: 'numeric',
								month: 'short',
								day: 'numeric',
							})}
						</time>
					</p>
				)}
			</header>

			{heroImage && (
				<figure class="post-hero">
					<Image width={720} height={405} src={heroImage} alt="" />
				</figure>
			)}

			<div class="prose">
				<slot />
			</div>

			<Divider class="post-divider" />

			<nav class="post-nav" aria-label={L.postNavigation}>
				<div class="post-nav__row">
					<div class="post-nav__cell post-nav__cell--prev">
						{prevPost ? (
							<a href={prevPost.href} class="post-nav__link" rel="prev">
								<span class="post-nav__label">{L.prevArticle}</span>
								<span class="post-nav__title">{prevPost.title}</span>
							</a>
						) : (
							<span class="post-nav__empty" />
						)}
					</div>
					<div class="post-nav__cell post-nav__cell--next">
						{nextPost ? (
							<a href={nextPost.href} class="post-nav__link post-nav__link--next" rel="next">
								<span class="post-nav__label">{L.nextArticle}</span>
								<span class="post-nav__title">{nextPost.title}</span>
							</a>
						) : (
							<span class="post-nav__empty" />
						)}
					</div>
				</div>
				<p class="post-nav__back">
					<a href={blogIndexHref}>{L.backToBlog}</a>
				</p>
			</nav>
		</article>

		<aside class="post-sidebar">
			<TableOfContents headings={headings} lang={lang} />
		</aside>
	</div>
</BaseLayout>

<style>
	/* ---- 2-Column Layout ---- */
	.post-layout {
		display: grid;
		grid-template-columns: minmax(0, var(--qv-container-prose)) 220px;
		gap: 48px;
		max-width: calc(var(--qv-container-prose) + 220px + 48px);
		margin: 0 auto;
		padding: 0 24px;
		box-sizing: border-box;
	}

	.post-content {
		min-width: 0;
	}

	.post-sidebar {
		min-width: 0;
	}

	/* ---- Header ---- */
	.post-header {
		margin: 32px 0 28px;
	}

	.post-header__eyebrow {
		margin-bottom: 14px;
	}

	.post-header__title {
		font-size: clamp(28px, 4vw, 38px);
		font-weight: 400;
		letter-spacing: -0.04em;
		line-height: 1.15;
		margin: 0 0 16px;
		color: var(--qv-text-1);
	}

	.post-header__updated {
		font-size: 13px;
		color: var(--qv-text-4);
		font-style: italic;
		margin: 8px 0 0;
	}

	/* ---- Hero Image ---- */
	.post-hero {
		margin: 0 0 32px;
		border-radius: var(--qv-radius-md);
		overflow: hidden;
		border: 1px solid var(--border);
	}

	.post-hero :global(img) {
		width: 100%;
		height: auto;
		display: block;
		border-radius: 0;
		border: none;
	}

	/* ---- Divider ---- */
	.post-divider {
		margin: 48px 0 32px;
	}

	/* ---- Post Navigation ---- */
	.post-nav {
		margin-bottom: 48px;
	}

	.post-nav__row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
		align-items: stretch;
	}

	.post-nav__cell {
		min-width: 0;
	}

	.post-nav__cell--next {
		text-align: right;
	}

	.post-nav__link {
		display: flex;
		flex-direction: column;
		gap: 6px;
		padding: 14px 18px;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: var(--qv-radius-sm);
		color: inherit;
		text-decoration: none;
		height: 100%;
		box-sizing: border-box;
		transition: border-color var(--qv-duration) var(--qv-ease),
			background var(--qv-duration) var(--qv-ease);
	}

	.post-nav__link:hover {
		border-color: var(--qv-line-active);
		background: var(--surface-hover);
		text-decoration: none;
	}

	.post-nav__link--next {
		align-items: flex-end;
	}

	.post-nav__label {
		font-family: var(--qv-font-mono);
		font-size: 11px;
		font-weight: 600;
		color: var(--accent);
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}

	.post-nav__title {
		font-size: 14px;
		font-weight: 500;
		color: var(--qv-text-1);
		line-height: 1.4;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.post-nav__empty {
		display: block;
		min-height: 1px;
	}

	.post-nav__back {
		margin: 20px 0 0;
		text-align: center;
		font-size: 13px;
	}

	.post-nav__back a {
		color: var(--qv-text-3);
		text-decoration: none;
	}

	.post-nav__back a:hover {
		color: var(--accent);
	}

	/* ---- Responsive ---- */
	@media (max-width: 960px) {
		.post-layout {
			grid-template-columns: 1fr;
			gap: 0;
			padding: 0 18px;
		}

		.post-sidebar {
			display: none;
		}
	}

	@media (max-width: 520px) {
		.post-nav__row {
			grid-template-columns: 1fr;
		}

		.post-nav__cell--next {
			text-align: left;
		}

		.post-nav__link--next {
			align-items: flex-start;
		}

		.post-header__title {
			font-size: 26px;
		}
	}
</style>
