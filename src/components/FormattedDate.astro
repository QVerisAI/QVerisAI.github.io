---
import type { Locale } from '../i18n/config';

interface Props {
	date: Date;
	locale: Locale;
}

const { date, locale } = Astro.props;
const tag = locale === 'cn' ? 'zh-CN' : 'en-US';
---

<time datetime={date.toISOString()}>
	{
		date.toLocaleDateString(tag, {
			year: 'numeric',
			month: 'short',
			day: 'numeric',
		})
	}
</time>
