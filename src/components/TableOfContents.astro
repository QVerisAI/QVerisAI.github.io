---
import type { Locale } from '../i18n/config';
import { t } from '../i18n/labels';

interface TocItem {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	headings: TocItem[];
	lang: Locale;
}

const { headings, lang } = Astro.props;
const L = t(lang);

// Only include h2 and h3
const filtered = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filtered.length > 0 && (
	<nav class="toc" aria-label={L.tableOfContents}>
		<h4 class="toc__title">{L.tableOfContents}</h4>
		<ul class="toc__list">
			{filtered.map((h) => (
				<li class:list={['toc__item', { 'toc__item--nested': h.depth === 3 }]}>
					<a href={`#${h.slug}`} class="toc__link">{h.text}</a>
				</li>
			))}
		</ul>
	</nav>
)}

<style>
	.toc {
		position: sticky;
		top: calc(var(--qv-nav-height) + 32px);
		max-height: calc(100vh - var(--qv-nav-height) - 64px);
		overflow-y: auto;
		padding: 0;
	}

	.toc__title {
		font-family: var(--qv-font-mono);
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--qv-text-3);
		margin: 0 0 12px;
		padding: 0;
	}

	.toc__list {
		list-style: none;
		padding: 0;
		margin: 0;
		border-left: 1px solid var(--border);
	}

	.toc__item {
		margin: 0;
	}

	.toc__item--nested {
		padding-left: 12px;
	}

	.toc__link {
		display: block;
		padding: 5px 0 5px 16px;
		font-size: 13px;
		line-height: 1.4;
		color: var(--qv-text-3);
		text-decoration: none;
		border-left: 2px solid transparent;
		margin-left: -1px;
		transition: color 0.15s ease, border-color 0.15s ease;
	}

	.toc__link:hover {
		color: var(--qv-text-1);
		text-decoration: none;
	}

	/* Active state (set by toc-highlight.ts script) */
	.toc__link:global(.toc-active) {
		color: var(--accent);
		border-left-color: var(--accent);
	}

	@media (max-width: 960px) {
		.toc {
			display: none;
		}
	}
</style>
