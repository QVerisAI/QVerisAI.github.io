---
import type { Locale } from '../i18n/config';
import FormattedDate from './FormattedDate.astro';
import ReadingTime from './ReadingTime.astro';

interface Props {
	date: Date;
	readingTime?: number;
	category?: string;
	lang: Locale;
}

const { date, readingTime, category, lang } = Astro.props;
---

<div class="post-meta">
	<FormattedDate date={date} locale={lang} />
	{readingTime && (
		<>
			<span class="post-meta__dot" aria-hidden="true">&middot;</span>
			<ReadingTime minutes={readingTime} lang={lang} />
		</>
	)}
	{category && (
		<>
			<span class="post-meta__dot" aria-hidden="true">&middot;</span>
			<span class="badge">{category}</span>
		</>
	)}
</div>

<style>
	.post-meta {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 6px;
		color: var(--qv-text-3);
		font-size: 0.88rem;
	}

	.post-meta__dot {
		color: var(--qv-text-4);
		user-select: none;
	}
</style>
