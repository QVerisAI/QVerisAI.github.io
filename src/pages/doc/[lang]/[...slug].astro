---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import DocPage from '../../../layouts/DocPage.astro';
import { type Locale, isLocale } from '../../../i18n/config';

export async function getStaticPaths() {
	const pages = await getCollection('doc');
	return pages.map((entry) => {
		const [lang, ...slugParts] = entry.id.split('/');
		if (!isLocale(lang)) {
			throw new Error(`Invalid locale in content id: ${entry.id}`);
		}
		const slug = slugParts.join('/');
		return {
			params: { lang, slug },
			props: { page: entry },
		};
	});
}

type Props = {
	page: CollectionEntry<'doc'>;
};

const { page } = Astro.props;
const { lang: langParam } = Astro.params;
const lang = isLocale(langParam ?? '') ? (langParam as Locale) : 'en';
const { Content } = await render(page);
---

<DocPage {...page.data} lang={lang}>
	<Content />
</DocPage>
