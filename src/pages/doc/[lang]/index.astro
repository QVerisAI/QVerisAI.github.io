---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import ScrollReveal from '../../../components/ScrollReveal.astro';
import Eyebrow from '../../../components/Eyebrow.astro';
import { isLocale } from '../../../i18n/config';
import { getStaticLocalePaths, localizedPath } from '../../../i18n/utils';
import { t } from '../../../i18n/labels';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../../consts';

export function getStaticPaths() {
	return getStaticLocalePaths();
}

const { lang: langParam } = Astro.params;
const lang = isLocale(langParam ?? '') ? langParam : 'en';
const L = t(lang);

const pages = (await getCollection('doc'))
	.filter((p) => p.id.startsWith(`${lang}/`))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={`${L.doc} — ${SITE_TITLE}`} description={SITE_DESCRIPTION} lang={lang} section="doc">
	<section class="doc-list-section">
		<div class="container--docs">
			<ScrollReveal>
				<Eyebrow text={L.doc} />
				<h1 class="doc-list__title">{L.doc}</h1>
			</ScrollReveal>

			<ul class="doc-list">
				{pages.map((page, i) => {
					const slug = page.id.replace(`${lang}/`, '');
					return (
						<li class="reveal" style={`--reveal-delay: ${0.15 + i * 0.09}s`}>
							<a href={localizedPath(lang, `/doc/${slug}`)} class="doc-card surface">
								{page.data.heroImage && (
									<div class="doc-card__thumb">
										<Image width={480} height={270} src={page.data.heroImage} alt="" />
									</div>
								)}
								<div class="doc-card__body">
									<h2 class="doc-card__title">{page.data.title}</h2>
									<p class="doc-card__desc">{page.data.description}</p>
									<p class="doc-card__date">
										<FormattedDate date={page.data.pubDate} locale={lang} />
									</p>
								</div>
							</a>
						</li>
					);
				})}
			</ul>

			{pages.length === 0 && (
				<p class="empty-state">No documentation yet.</p>
			)}
		</div>
	</section>
</BaseLayout>

<style>
	.container--docs {
		max-width: var(--qv-container-blog);
		margin: 0 auto;
		padding: 0 24px;
		box-sizing: border-box;
	}

	.doc-list-section {
		padding: 48px 0 var(--qv-spacing-section);
	}

	.doc-list__title {
		font-size: clamp(26px, 3.5vw, 34px);
		font-weight: 400;
		letter-spacing: -0.035em;
		margin: 14px 0 32px;
	}

	.doc-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.doc-card {
		display: flex;
		gap: 20px;
		align-items: flex-start;
		padding: 0;
		color: inherit;
		text-decoration: none;
		overflow: hidden;
	}

	.doc-card:hover {
		text-decoration: none;
	}

	.doc-card__thumb {
		flex-shrink: 0;
		width: 200px;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(
			180deg,
			rgba(255, 255, 255, 0.03) 0%,
			var(--surface) 100%
		);
	}

	.doc-card__thumb :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		border: none;
	}

	.doc-card__body {
		padding: 20px 24px 20px 0;
		min-width: 0;
	}

	.doc-card__title {
		margin: 0 0 6px;
		font-size: 1.1rem;
		font-weight: 550;
		color: var(--qv-text-1);
		transition: color 0.15s ease;
	}

	.doc-card:hover .doc-card__title {
		color: var(--accent);
	}

	.doc-card__desc {
		margin: 0;
		color: var(--qv-text-3);
		font-size: 14px;
		line-height: 1.55;
	}

	.doc-card__date {
		margin: 10px 0 0;
		font-size: 13px;
		color: var(--qv-text-4);
	}

	.empty-state {
		text-align: center;
		color: var(--qv-text-3);
		padding: 64px 0;
	}

	@media (max-width: 560px) {
		.doc-card {
			flex-direction: column;
			gap: 0;
		}

		.doc-card__thumb {
			width: 100%;
		}

		.doc-card__body {
			padding: 16px 20px 20px;
		}

		.container--docs {
			padding: 0 18px;
		}
	}
</style>
