---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import EmbedToolbar from '../../../components/EmbedToolbar.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import { isLocale } from '../../../i18n/config';
import { getStaticLocalePaths, localizedPath } from '../../../i18n/utils';
import { t } from '../../../i18n/labels';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../../consts';

export function getStaticPaths() {
	return getStaticLocalePaths();
}

const { lang: langParam } = Astro.params;
const lang = isLocale(langParam ?? '') ? langParam : 'en';
const L = t(lang);
const htmlLang = lang === 'cn' ? 'zh-CN' : 'en';

const pages = (await getCollection('doc'))
	.filter((p) => p.id.startsWith(`${lang}/`))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang={htmlLang}>
	<head>
		<BaseHead title={`${L.doc} — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			ul.docs {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}
			ul.docs li a {
				display: flex;
				gap: 1rem;
				align-items: flex-start;
				padding: 1rem 1.1rem;
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 12px;
				color: inherit;
				text-decoration: none;
				transition:
					border-color 0.15s ease,
					background 0.15s ease;
			}
			ul.docs li a:hover {
				border-color: var(--accent);
				background: var(--surface-hover);
			}
			ul.docs .thumb {
				flex-shrink: 0;
				width: 120px;
				border-radius: 8px;
				overflow: hidden;
				border: 1px solid var(--border);
			}
			ul.docs .thumb img {
				display: block;
				width: 100%;
				height: auto;
			}
			ul.docs .meta h2 {
				margin: 0 0 0.35rem;
				font-size: 1.15rem;
			}
			ul.docs .meta p {
				margin: 0;
				color: var(--muted);
				font-size: 0.92rem;
			}
			ul.docs .meta .date {
				margin-top: 0.5rem;
				font-size: 0.85rem;
			}
			@media (max-width: 560px) {
				ul.docs li a {
					flex-direction: column;
				}
				ul.docs .thumb {
					width: 100%;
				}
			}
		</style>
	</head>
	<body class="embed-body">
		<EmbedToolbar lang={lang} section="doc" />
		<main class="embed-main">
			<ul class="docs">
				{
					pages.map((page) => {
						const slug = page.id.replace(`${lang}/`, '');
						return (
							<li>
								<a href={localizedPath(lang, `/doc/${slug}`)}>
									{page.data.heroImage && (
										<div class="thumb">
											<Image width={240} height={120} src={page.data.heroImage} alt="" />
										</div>
									)}
									<div class="meta">
										<h2>{page.data.title}</h2>
										<p>{page.data.description}</p>
										<p class="date">
											<FormattedDate date={page.data.pubDate} locale={lang} />
										</p>
									</div>
								</a>
							</li>
						);
					})
				}
			</ul>
		</main>
	</body>
</html>
