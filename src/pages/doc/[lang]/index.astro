---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import EmbedToolbar from '../../../components/EmbedToolbar.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import { isLocale } from '../../../i18n/config';
import { getStaticLocalePaths, localizedPath } from '../../../i18n/utils';
import { t } from '../../../i18n/labels';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../../consts';

export function getStaticPaths() {
	return getStaticLocalePaths();
}

const { lang: langParam } = Astro.params;
const lang = isLocale(langParam ?? '') ? langParam : 'en';
const L = t(lang);
const htmlLang = lang === 'cn' ? 'zh-CN' : 'en';

const pages = (await getCollection('doc'))
	.filter((p) => p.id.startsWith(`${lang}/`))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang={htmlLang}>
	<head>
		<BaseHead title={`${L.doc} — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.embed-main {
				padding-top: 0.5rem;
				max-width: 880px;
			}
			ul.docs {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}
			ul.docs li a {
				display: flex;
				gap: 1rem;
				align-items: flex-start;
				padding: 1rem 1.1rem;
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 12px;
				color: inherit;
				text-decoration: none;
				transition:
					border-color 0.15s ease,
					background 0.15s ease;
			}
			ul.docs li a:hover {
				border-color: var(--accent);
				background: var(--surface-hover);
			}
			/* Matches blog list `.post-thumb` */
			.post-thumb {
				flex-shrink: 0;
				width: 200px;
				max-width: min(200px, 38vw);
				aspect-ratio: 16 / 9;
				max-height: 140px;
				border-radius: 8px;
				background: linear-gradient(
					180deg,
					rgba(255, 255, 255, 0.05) 0%,
					color-mix(in srgb, var(--qv-bg) 72%, transparent) 100%
				);
				border: 1px solid var(--border);
				display: flex;
				align-items: center;
				justify-content: center;
				overflow: hidden;
				box-sizing: border-box;
			}
			.post-thumb :global(img) {
				max-height: 85%;
				max-width: 85%;
				width: auto;
				height: auto;
				object-fit: contain;
				border-radius: 4px;
				display: block;
			}
			ul.docs .meta {
				min-width: 0;
			}
			ul.docs .meta h2 {
				margin: 0 0 0.35rem;
				font-size: 1.15rem;
				transition: color 0.15s ease;
			}
			ul.docs li a:hover .meta h2 {
				color: var(--accent);
			}
			ul.docs .meta p {
				margin: 0;
				color: var(--muted);
				font-size: 0.92rem;
			}
			ul.docs .meta .date {
				margin-top: 0.5rem;
				font-size: 0.85rem;
			}
			@media (max-width: 560px) {
				ul.docs li a {
					flex-direction: column;
				}
				.post-thumb {
					width: 100%;
					max-width: none;
				}
			}
		</style>
	</head>
	<body class="embed-body">
		<EmbedToolbar lang={lang} section="doc" />
		<main class="embed-main">
			<ul class="docs">
				{
					pages.map((page) => {
						const slug = page.id.replace(`${lang}/`, '');
						return (
							<li>
								<a href={localizedPath(lang, `/doc/${slug}`)}>
									{page.data.heroImage && (
										<div class="post-thumb">
											<Image width={480} height={270} src={page.data.heroImage} alt="" />
										</div>
									)}
									<div class="meta">
										<h2>{page.data.title}</h2>
										<p>{page.data.description}</p>
										<p class="date">
											<FormattedDate date={page.data.pubDate} locale={lang} />
										</p>
									</div>
								</a>
							</li>
						);
					})
				}
			</ul>
		</main>
	</body>
</html>
