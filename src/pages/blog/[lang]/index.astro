---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import EmbedToolbar from '../../../components/EmbedToolbar.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import { isLocale } from '../../../i18n/config';
import { getStaticLocalePaths, localizedPath } from '../../../i18n/utils';
import { t } from '../../../i18n/labels';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../../consts';

export function getStaticPaths() {
	return getStaticLocalePaths();
}

const { lang: langParam } = Astro.params;
const lang = isLocale(langParam ?? '') ? langParam : 'en';
const L = t(lang);
const htmlLang = lang === 'cn' ? 'zh-CN' : 'en';

const posts = (await getCollection('blog'))
	.filter((p) => p.id.startsWith(`${lang}/`))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang={htmlLang}>
	<head>
		<BaseHead title={`${L.blog} — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.embed-main {
				padding-top: 0.5rem;
				max-width: 880px;
			}
			ul.posts {
				display: flex;
				flex-wrap: wrap;
				gap: 1.75rem 1.25rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			ul.posts > li {
				flex: 1 1 240px;
				min-width: min(100%, 240px);
				max-width: 100%;
				display: flex;
				flex-direction: column;
				box-sizing: border-box;
			}
			ul.posts li a {
				display: flex;
				flex-direction: column;
				flex: 1 1 auto;
				min-height: 0;
				color: inherit;
				text-decoration: none;
				padding: 0.65rem 0.65rem 0.75rem;
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 12px;
				transition:
					border-color 0.15s ease,
					background 0.15s ease;
			}
			ul.posts li a:hover {
				border-color: var(--accent);
				background: var(--surface-hover);
			}
			.post-thumb {
				aspect-ratio: 16 / 9;
				max-height: 140px;
				width: 100%;
				margin-bottom: 0.65rem;
				border-radius: 8px;
				background: rgba(0, 0, 0, 0.2);
				border: 1px solid var(--border);
				display: flex;
				align-items: center;
				justify-content: center;
				overflow: hidden;
				box-sizing: border-box;
			}
			.post-thumb :global(img) {
				max-height: 85%;
				max-width: 85%;
				width: auto;
				height: auto;
				object-fit: contain;
				border-radius: 4px;
			}
			.title {
				margin: 0;
				color: var(--text);
				line-height: 1.3;
				font-size: 1.05rem;
				font-weight: 600;
			}
			.date {
				margin: 0.35rem 0 0;
				color: var(--muted);
				font-size: 0.85rem;
			}
			ul.posts li a:hover .title {
				color: var(--accent);
			}
			@media (max-width: 520px) {
				ul.posts > li {
					flex-basis: 100%;
					min-width: 0;
				}
			}
		</style>
	</head>
	<body class="embed-body">
		<EmbedToolbar lang={lang} section="blog" />
		<main class="embed-main">
			<section>
				<ul class="posts">
					{
						posts.map((post) => {
							const slug = post.id.replace(`${lang}/`, '');
							return (
								<li>
									<a href={localizedPath(lang, `/blog/${slug}`)}>
										{post.data.heroImage && (
											<div class="post-thumb">
												<Image width={480} height={270} src={post.data.heroImage} alt="" />
											</div>
										)}
										<h2 class="title">{post.data.title}</h2>
										<p class="date">
											<FormattedDate date={post.data.pubDate} locale={lang} />
										</p>
									</a>
								</li>
							);
						})
					}
				</ul>
			</section>
		</main>
	</body>
</html>
