---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogHero from '../../../components/BlogHero.astro';
import Divider from '../../../components/Divider.astro';
import PostCard from '../../../components/PostCard.astro';
import ScrollReveal from '../../../components/ScrollReveal.astro';
import Eyebrow from '../../../components/Eyebrow.astro';
import { isLocale } from '../../../i18n/config';
import { getStaticLocalePaths, localizedPath } from '../../../i18n/utils';
import { t } from '../../../i18n/labels';
import { SITE_TITLE } from '../../../consts';
import { getReadingTime } from '../../../utils/reading-time';

export function getStaticPaths() {
	return getStaticLocalePaths();
}

const { lang: langParam } = Astro.params;
const lang = isLocale(langParam ?? '') ? langParam : 'en';
const L = t(lang);

const allPosts = (await getCollection('blog'))
	.filter((p) => p.id.startsWith(`${lang}/`))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Separate featured post
const featuredPost = allPosts.find((p) => p.data.featured) ?? null;
const posts = featuredPost
	? allPosts.filter((p) => p.id !== featuredPost.id)
	: allPosts;

function postHref(post: (typeof allPosts)[0]) {
	const slug = post.id.replace(`${lang}/`, '');
	return localizedPath(lang, `/blog/${slug}`);
}
---

<BaseLayout title={`${L.blog} — ${SITE_TITLE}`} description={L.blogDescription} lang={lang} section="blog">
	<BlogHero
		eyebrow={L.blogEyebrow}
		title={L.blogTitle}
		description={L.blogDescription}
	/>

	<Divider />

	{featuredPost && (
		<section class="featured-section">
			<div class="container--blog">
				<ScrollReveal delay={0.1}>
					<Eyebrow text={L.featuredPost} />
					<div class="featured-card">
						<PostCard
							post={featuredPost}
							href={postHref(featuredPost)}
							readingTime={getReadingTime(featuredPost.body ?? '')}
							lang={lang}
							featured={true}
						/>
					</div>
				</ScrollReveal>
			</div>
		</section>
	)}

	<section class="posts-section">
		<div class="container--blog">
			{posts.length > 0 && (
				<ScrollReveal delay={0.2}>
					{posts.length > 0 && !featuredPost && (
						<Eyebrow text={L.allPosts} class="posts-eyebrow" />
					)}
					<div class="post-grid">
						{posts.map((post, i) => (
							<div class="post-grid__item reveal" style={`--reveal-delay: ${0.25 + i * 0.09}s`}>
								<PostCard
									post={post}
									href={postHref(post)}
									readingTime={getReadingTime(post.body ?? '')}
									lang={lang}
								/>
							</div>
						))}
					</div>
				</ScrollReveal>
			)}

			{allPosts.length === 0 && (
				<p class="empty-state">{L.noPosts}</p>
			)}
		</div>
	</section>
</BaseLayout>

<style>
	.container--blog {
		max-width: var(--qv-container-blog);
		margin: 0 auto;
		padding: 0 24px;
		box-sizing: border-box;
	}

	.featured-section {
		padding: 48px 0;
	}

	.featured-card {
		margin-top: 20px;
	}

	.posts-section {
		padding: 32px 0 var(--qv-spacing-section);
	}

	.posts-eyebrow {
		margin-bottom: 24px;
	}

	.post-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 24px;
		margin-top: 24px;
	}

	.post-grid__item {
		min-width: 0;
	}

	.empty-state {
		text-align: center;
		color: var(--qv-text-3);
		padding: 64px 0;
		font-size: 16px;
	}

	@media (max-width: 700px) {
		.featured-section {
			padding: 32px 0;
		}

		.posts-section {
			padding: 24px 0 var(--qv-spacing-section);
		}

		.post-grid {
			grid-template-columns: 1fr;
			gap: 20px;
		}

		.container--blog {
			padding: 0 18px;
		}
	}
</style>
